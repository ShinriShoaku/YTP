{
  "tiktok_username": "@masukan-user-name",
  "commands": {
    "request": ["#req", "#request", "#lagu", "#song", "#minta"],
    "skip":    ["#skip", "#next", "#lewat", "#ganti"],
    "stop":    ["#stop"],
    "queue":   ["#queue", "#antrian", "#q", "#list"]
  },
  "settings": {
    "max_queue_per_user": 3,
    "enable_skip_vote": true,
    "skip_vote_threshold": 5
  },
  "overlay": {
    "_comment_mode": "Pilih mode: 'combined' = 1 browser source /obs | 'modular' = tiap panel URL terpisah",
    "overlay_mode": "modular",

    "_comment_panels": "Toggle tiap elemen — berlaku untuk mode combined DAN modular",
    "show_now_playing":    true,
    "show_queue":          true,
    "show_request_feed":   false,
    "show_commands_hint":  true,
    "show_skip_vote":      true,
    "show_next_up":        true,
    "show_progress_bar":   true,
    "show_thumbnail":      true,
    "show_requester":      true,
    "show_channel":        true,
    "show_tiktok_dot":     true,
    "show_subtitle":       true,

    "_comment_limits": "Berapa baris yang ditampilkan di panel",
    "max_queue_items":     6,
    "max_request_items":   8,

    "_comment_style": "Warna, ukuran font, opacity panel",
    "accent_color":        "#f97316",
    "accent_color2":       "#a855f7",
    "font_size_title":     20,
    "subtitle_font_size":  30,
    "opacity_panels":      0.82,

    "_comment_position": "Posisi panel: 'right'|'left' untuk queue, 'right'|'left'|'hidden' untuk commands",
    "position_queue":      "right",
    "position_commands":   "left",

    "_comment_obs_urls": "URL Browser Source di OBS — sesuaikan port jika beda",
    "_obs_combined":     "http://localhost:8000/obs",
    "_obs_nowplaying":   "http://localhost:8000/obs/nowplaying",
    "_obs_queue":        "http://localhost:8000/obs/queue",
    "_obs_commands":     "http://localhost:8000/obs/commands",
    "_obs_subtitle":     "http://localhost:8000/obs/subtitle",
    "_obs_requests":     "http://localhost:8000/obs/requests"
  }
}
